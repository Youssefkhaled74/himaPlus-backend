        { "name": "Get Or Create Conversation", "request": { "method": "GET", "url": "{{base_url}}/api/chat/conversation?receiver_id={{receiver_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["try { const json = pm.response.json(); const conversation = json?.data; if (conversation?.id) pm.collectionVariables.set('conversation_id', String(conversation.id)); } catch (error) {}"] } }] },
        { "name": "Messages", "request": { "method": "GET", "url": "{{base_url}}/api/chat/conversation/{{conversation_id}}/{{offset}}/{{limit}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["try { const json = pm.response.json(); const first = json?.data?.messages?.[0]; if (first?.id) pm.collectionVariables.set('message_id', String(first.id)); } catch (error) {}"] } }] },
        { "name": "Send Message", "request": { "method": "POST", "body": { "mode": "formdata", "formdata": [{ "key": "receiver_id", "value": "{{receiver_id}}", "type": "text" }, { "key": "message", "value": "Hello from Postman", "type": "text" }, { "key": "file", "src": "{{sample_file}}", "type": "file", "disabled": true }] }, "url": "{{base_url}}/api/chat/messages/send" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["try { const json = pm.response.json(); const message = json?.data; if (message?.id) pm.collectionVariables.set('message_id', String(message.id)); if (message?.conversation_id) pm.collectionVariables.set('conversation_id', String(message.conversation_id)); } catch (error) {}"] } }] },
        { "name": "Mark As Read", "request": { "method": "GET", "url": "{{base_url}}/api/chat/messages/mark-as-read/{{conversation_id}}" } },
        { "name": "Delete Message", "request": { "method": "GET", "url": "{{base_url}}/api/chat/messages/delete/{{message_id}}" } },
        { "name": "Unread Count", "request": { "method": "GET", "url": "{{base_url}}/api/chat/unread-count/{{conversation_id}}" } },
        { "name": "Toggle Block Conversation", "request": { "method": "POST", "url": "{{base_url}}/api/chat/conversations/{{conversation_id}}/toggle-block" }, "event": [{ "listen": "prerequest", "script": { "type": "text/javascript", "exec": ["pm.variables.set('assert_response_wrapper', 'false');"] } }] }
      ]
    },
    {
      "name": "Ratings",
      "item": [
        { "name": "Create Rating", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Smoke test rating\",\n  \"for_id\": {{product_id}},\n  \"for_type\": \"Product\"\n}", "options": { "raw": { "language": "json" } } }, "url": "{{base_url}}/api/ratings" } }
      ]
    }
  ]
}
