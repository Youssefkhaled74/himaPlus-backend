  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const expectedHttpStatus = Number(pm.variables.get('expected_http_status') || 200);",
          "pm.test('HTTP status matches expected', function () {",
          "  pm.expect(pm.response.code).to.eql(expectedHttpStatus);",
          "});",
          "try {",
          "  const json = pm.response.json();",
          "  pm.collectionVariables.set('last_response_json', JSON.stringify(json));",
          "  if (pm.variables.get('assert_response_wrapper') !== 'false' && typeof json.status === 'number') {",
          "    const expectedBodyStatus = Number(pm.variables.get('expected_body_status') || expectedHttpStatus);",
          "    pm.test('Response body status matches expected', function () {",
          "      pm.expect(json.status).to.eql(expectedBodyStatus);",
          "    });",
          "  }",
          "} catch (error) {}",
          "pm.variables.unset('expected_http_status');",
          "pm.variables.unset('expected_body_status');",
          "pm.variables.unset('assert_response_wrapper');"
        ]
      }
    }
  ],
